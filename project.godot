; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ReadingRacer"
run/main_scene="res://scenes/level_select.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Diagnostic="*res://scripts/reading/startup_diagnostic.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/Godot-MToon-Shader/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/unidot_importer/plugin.cfg")

[gdunit4]

settings/test/test_timeout_seconds=1
settings/test/test_discovery=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method.mobile="forward_plus"
